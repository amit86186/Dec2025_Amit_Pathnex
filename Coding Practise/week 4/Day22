# creating s3 bucket via teraform 

provider "aws" {
  region = "ap-south-1" #mumbai =region
}
resource "aws_s3_bucket" "mybucket" {
  bucket = "ami-unique-bucket-name-123"

tags = {
 Name = "my_bucket"
 env  = "prod"
 }
}

versioning {
 enabled = true 
 }
}

==================end===========================










